# Required for AI story/image generation (via Replit AI Integrations)
AI_INTEGRATIONS_GEMINI_API_KEY=
AI_INTEGRATIONS_GEMINI_BASE_URL=

# Required for OpenAI integrations (chat, audio — via Replit AI Integrations)
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# Required for text-to-speech (via Replit ElevenLabs connector)
# The connector auto-provisions credentials; no manual key needed.
# ELEVENLABS_API_KEY is set by the connector at runtime.

# Required for database (auto-provisioned by Replit)
DATABASE_URL=

# Session secret for auth
SESSION_SECRET=

# Set automatically by Replit — do not set manually
# REPLIT_DEV_DOMAIN=
# REPLIT_DOMAINS=
# REPL_IDENTITY=
# WEB_REPL_RENEWAL=
# REPLIT_CONNECTORS_HOSTNAME=
# PORT=5000

# Set by Expo dev script — do not set manually
# EXPO_PUBLIC_DOMAIN=
